<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Kindling Mobile" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application.bootstrap", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      :root {
        --mobile-cream: #f7f1e8;
        --mobile-paper: rgba(255, 252, 247, 0.96);
        --mobile-ink: #193042;
        --mobile-muted: #6a706f;
        --mobile-line: rgba(25, 48, 66, 0.10);
        --mobile-accent: #2f755a;
        --mobile-accent-deep: #1f5a45;
        --mobile-accent-soft: rgba(47, 117, 90, 0.12);
        --mobile-danger: #a24637;
        --mobile-shadow: 0 28px 60px rgba(31, 42, 56, 0.12);
      }

      html, body {
        min-height: 100%;
      }

      body {
        margin: 0;
        color: var(--mobile-ink);
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.82), transparent 35%),
          linear-gradient(180deg, #fcf7f0 0%, var(--mobile-cream) 52%, #f0e7d8 100%);
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
      }

      .mobile-shell {
        max-width: 34rem;
        min-height: 100vh;
        margin: 0 auto;
        padding: 1.25rem 1rem calc(2rem + env(safe-area-inset-bottom, 0px));
      }

      .mobile-card {
        background: var(--mobile-paper);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 1.75rem;
        box-shadow: var(--mobile-shadow);
        padding: 1.35rem;
        backdrop-filter: blur(10px);
      }

      .mobile-brand {
        display: flex;
        justify-content: center;
        margin-bottom: 1.15rem;
      }

      .mobile-brand img {
        max-width: 9.5rem;
        height: auto;
      }

      .mobile-stepbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }

      .mobile-step-pill,
      .mobile-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.72rem;
        font-weight: 700;
      }

      .mobile-step-pill {
        color: var(--mobile-accent-deep);
        background: var(--mobile-accent-soft);
        padding: 0.45rem 0.8rem;
      }

      .mobile-eyebrow {
        color: var(--mobile-muted);
        margin-bottom: 0.55rem;
      }

      .mobile-back-link {
        color: var(--mobile-ink);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 700;
      }

      .mobile-title {
        font-size: clamp(2rem, 6vw, 2.65rem);
        line-height: 1.05;
        margin: 0 0 0.65rem;
        letter-spacing: -0.03em;
      }

      .mobile-subtitle,
      .mobile-copy,
      .mobile-muted {
        color: var(--mobile-muted);
        font-size: 1rem;
        line-height: 1.55;
      }

      .mobile-copy strong {
        color: var(--mobile-ink);
      }

      .mobile-stack {
        display: grid;
        gap: 1rem;
      }

      .mobile-section {
        padding-top: 1rem;
        border-top: 1px solid var(--mobile-line);
      }

      .mobile-section:first-of-type {
        border-top: 0;
        padding-top: 0;
      }

      .mobile-section-title {
        font-size: 1.12rem;
        margin: 0 0 0.65rem;
      }

      .mobile-form-group {
        display: grid;
        gap: 0.45rem;
        margin-bottom: 1rem;
      }

      .mobile-form-group:last-child {
        margin-bottom: 0;
      }

      .mobile-field-label {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0;
      }

      .mobile-input,
      .mobile-select,
      .mobile-input-number {
        width: 100%;
        border-radius: 1rem;
        border: 1px solid var(--mobile-line);
        background: rgba(255, 255, 255, 0.96);
        color: var(--mobile-ink);
        padding: 0.92rem 1rem;
        font-size: 1rem;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .mobile-input:focus,
      .mobile-select:focus,
      .mobile-input-number:focus {
        border-color: rgba(47, 117, 90, 0.45);
        outline: 0;
        box-shadow: 0 0 0 0.24rem rgba(47, 117, 90, 0.14);
      }

      .mobile-inline-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
      }

      .mobile-radio-group {
        display: grid;
        gap: 0.7rem;
      }

      .mobile-radio-group[data-mobile-collapsible="true"].is-collapsed .mobile-radio-option:not(.is-selected) {
        display: none;
      }

      .mobile-radio-option {
        position: relative;
      }

      .mobile-radio-option input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }

      .mobile-radio-option label {
        display: block;
        padding: 0.92rem 1rem;
        border: 1px solid var(--mobile-line);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.92);
        font-weight: 700;
        cursor: pointer;
        transition: 0.18s ease;
      }

      .mobile-radio-option input:checked + label {
        border-color: rgba(47, 117, 90, 0.42);
        background: rgba(240, 248, 244, 0.98);
        box-shadow: 0 10px 20px rgba(47, 117, 90, 0.12);
        transform: translateY(-1px);
      }

      .mobile-radio-group[data-mobile-collapsible="true"].is-collapsed .mobile-radio-option.is-selected label {
        padding-right: 3.4rem;
      }

      .mobile-radio-reset {
        position: absolute;
        top: 50%;
        right: 0.65rem;
        transform: translateY(-50%);
        width: 2rem;
        height: 2rem;
        border: 0;
        border-radius: 999px;
        background: rgba(47, 117, 90, 0.12);
        color: var(--mobile-accent-deep);
        font-size: 1rem;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }

      .mobile-radio-reset[hidden] {
        display: none;
      }

      .mobile-actions {
        display: grid;
        gap: 0.75rem;
        margin-top: 1.4rem;
      }

      .mobile-button,
      .mobile-button-secondary,
      .mobile-button-tertiary {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        border-radius: 999px;
        padding: 0.92rem 1.15rem;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        border: 0;
        transition: 0.18s ease;
      }

      .mobile-button {
        color: #fff;
        background: linear-gradient(180deg, var(--mobile-accent) 0%, var(--mobile-accent-deep) 100%);
        box-shadow: 0 16px 30px rgba(31, 90, 69, 0.22);
      }

      .mobile-button:hover,
      .mobile-button:focus {
        color: #fff;
        transform: translateY(-1px);
      }

      .mobile-button:disabled {
        opacity: 0.56;
        box-shadow: none;
        transform: none;
      }

      .mobile-button-secondary {
        color: var(--mobile-ink);
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid var(--mobile-line);
      }

      .mobile-button-tertiary {
        color: var(--mobile-accent-deep);
        background: transparent;
      }

      .mobile-form-error,
      .mobile-flash-alert,
      .mobile-flash-notice {
        border-radius: 1rem;
        padding: 0.85rem 1rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
      }

      .mobile-form-error,
      .mobile-flash-alert {
        color: var(--mobile-danger);
        background: rgba(162, 70, 55, 0.10);
        border: 1px solid rgba(162, 70, 55, 0.16);
      }

      .mobile-flash-notice {
        color: var(--mobile-accent-deep);
        background: rgba(47, 117, 90, 0.10);
        border: 1px solid rgba(47, 117, 90, 0.16);
      }

      .mobile-list {
        padding-left: 1.1rem;
        color: var(--mobile-muted);
        margin: 0;
      }

      .mobile-list li + li {
        margin-top: 0.45rem;
      }

      .mobile-child-card {
        border-radius: 1.35rem;
        padding: 1rem;
        border: 1px solid rgba(25, 48, 66, 0.08);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(249, 246, 241, 0.96));
      }

      .mobile-child-topline {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
      }

      .mobile-child-title {
        margin: 0;
        font-size: 1rem;
      }

      .mobile-remove-button {
        border: 0;
        background: transparent;
        color: var(--mobile-danger);
        font-weight: 700;
        padding: 0;
      }

      .mobile-helper {
        font-size: 0.88rem;
        color: var(--mobile-muted);
      }

      .mobile-link {
        color: var(--mobile-accent-deep);
        text-decoration: none;
        font-weight: 700;
      }

      .mobile-rule {
        margin: 1rem 0;
        border: 0;
        border-top: 1px solid var(--mobile-line);
      }

      .mobile-stat-block {
        border-radius: 1.2rem;
        padding: 0.95rem 1rem;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(25, 48, 66, 0.08);
      }

      @media (max-width: 640px) {
        .mobile-inline-grid {
          grid-template-columns: 1fr;
        }

        .mobile-shell {
          padding-inline: 0.9rem;
        }

        .mobile-card {
          border-radius: 1.5rem;
          padding: 1.15rem;
        }
      }
    </style>
  </head>
  <body>
    <main class="mobile-shell">
      <% if notice.present? %>
        <div class="mobile-flash-notice"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="mobile-flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
