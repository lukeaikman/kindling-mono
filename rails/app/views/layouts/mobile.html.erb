<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Kindling Mobile" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "mobile", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags "mobile" %>
  </head>
  <body class="mobile-body">
    <div class="mobile-app">
      <main class="mobile-app__content">
        <div class="mobile-flash-stack">
          <% if notice.present? %>
            <div class="mobile-flash-notice"><%= notice %></div>
          <% end %>

          <% if alert.present? %>
            <div class="mobile-flash-alert"><%= alert %></div>
          <% end %>
        </div>

        <%= yield %>
      </main>

      <% if content_for?(:mobile_footer) %>
        <footer class="mobile-app__footer">
          <%= yield :mobile_footer %>
        </footer>
      <% end %>
    </div>
  </body>
</html>
