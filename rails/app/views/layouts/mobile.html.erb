<!DOCTYPE html>
<html>
  <head>
    <title>Kindling Mobile</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application.bootstrap", "data-turbo-track": "reload" %>
    <style>
      body { background: #f7f2e8; color: #1d2a38; }
      .mobile-shell { max-width: 560px; margin: 0 auto; padding: 2rem 1rem; }
      .card { border-radius: 16px; }
    </style>
  </head>
  <body>
    <main class="mobile-shell">
      <%= yield %>
    </main>
  </body>
</html>
