<!DOCTYPE html>
<html>
  <head>
    <title>Set new password - Kindling Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application.bootstrap", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-light">
    <div class="container">
      <div class="row min-vh-100 align-items-center justify-content-center">
        <div class="col-md-6 col-lg-5">
          <div class="card shadow">
            <div class="card-body p-5">
              <h2 class="card-title text-center mb-4">
                <strong>Choose a new password</strong>
              </h2>

              <% if alert %>
                <div class="alert alert-danger" role="alert"><%= alert %></div>
              <% end %>

              <%= form_with url: password_path(params[:token]), method: :put, local: true do |f| %>
                <div class="mb-3">
                  <%= f.label :password, "New password", class: "form-label" %>
                  <%= f.password_field :password, class: "form-control form-control-lg", required: true, autofocus: true %>
                </div>

                <div class="mb-4">
                  <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
                  <%= f.password_field :password_confirmation, class: "form-control form-control-lg", required: true %>
                </div>

                <div class="d-grid">
                  <%= f.submit "Save password", class: "btn btn-primary btn-lg" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
