<!DOCTYPE html>
<html>
  <head>
    <title>Login - Kindling Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application.bootstrap", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-light">
    <div class="container">
      <div class="row min-vh-100 align-items-center justify-content-center">
        <div class="col-md-6 col-lg-5">
          <div class="card shadow">
            <div class="card-body p-5">
              <h2 class="card-title text-center mb-4">
                <strong>Kindling Admin</strong>
              </h2>
              
              <% if alert %>
                <div class="alert alert-danger" role="alert">
                  <%= alert %>
                </div>
              <% end %>
              
              <%= form_with url: session_path, method: :post, local: true do |f| %>
                <div class="mb-3">
                  <%= f.label :email_address, "Email", class: "form-label" %>
                  <%= f.email_field :email_address, class: "form-control form-control-lg", required: true, autofocus: true, placeholder: "your@email.com" %>
                </div>
                
                <div class="mb-4">
                  <%= f.label :password, class: "form-label" %>
                  <%= f.password_field :password, class: "form-control form-control-lg", required: true, placeholder: "••••••••" %>
                </div>
                
                <div class="d-grid">
                  <%= f.submit "Sign in", class: "btn btn-primary btn-lg" %>
                </div>
              <% end %>
              
              <div class="text-center mt-4">
                <small class="text-muted">
                  <%= link_to "Forgot your password?", new_password_path, class: "text-decoration-none" %>
                </small>
              </div>
            </div>
          </div>
          
          <p class="text-center text-muted mt-4">
            <small>&copy; <%= Time.current.year %> Kindling. All rights reserved.</small>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>

