<div class="row">
  <div class="col-12">
    <h1 class="mb-4">Dashboard</h1>
    
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Welcome to Kindling Admin</h5>
        <p class="card-text">
          This is your admin dashboard. Use the navigation above to explore different sections.
        </p>
        <ul class="list-unstyled mt-3">
          <li class="mb-2">
            <strong>DB Viewer:</strong> Explore and search your database tables
          </li>
          <li class="mb-2">
            <strong>Settings:</strong> Update your profile and password
          </li>
          <li class="mb-2">
            <strong>About:</strong> Learn more about this application
          </li>
        </ul>
      </div>
    </div>
    
    <div class="card mt-4">
      <div class="card-body">
        <h5 class="card-title">Quick Stats</h5>
        <p class="text-muted">Logged in as: <%= Current.user.full_name %> (<%= Current.user.email_address %>)</p>
      </div>
    </div>
  </div>
</div>


