<% content_for :title, "" %>

<% footer_actions = capture do %>
  <%= button_to "Continue", mobile_complete_video_path, method: :post, class: "mobile-button" %>
<% end %>

<% content_for :mobile_footer do %>
  <%= render "mobile/shared/sticky_actions", body: footer_actions %>
<% end %>

<% media_body = capture do %>
  <video controls playsinline preload="metadata">
    <source src="<%= @video_url %>" type="video/mp4">
  </video>
<% end %>

<section class="mobile-screen mobile-screen--startup">
  <%= render "mobile/shared/screen_header" %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      eyebrow: "A quick welcome",
      title: "Take one minute to orient yourself.",
      subtitle: "This mirrors the startup gate in the native app before we move you into the main flow." %>

    <%= render "mobile/shared/media_frame", body: media_body %>
  </div>
</section>
