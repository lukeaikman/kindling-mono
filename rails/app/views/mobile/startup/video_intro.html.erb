<% content_for :title, "Kindling | Video Intro" %>

<div class="mobile-card">
  <%= render "mobile/shared/step_header" %>

  <p class="mobile-eyebrow">A quick welcome</p>
  <h1 class="mobile-title">Take one minute to orient yourself.</h1>
  <p class="mobile-subtitle">This mirrors the startup gate in the native app before we move you into the main flow.</p>

  <video controls playsinline class="w-100 mb-4 rounded-4" preload="metadata">
    <source src="<%= @video_url %>" type="video/mp4">
  </video>

  <div class="mobile-actions">
    <%= button_to "Continue", mobile_complete_video_path, method: :post, class: "mobile-button" %>
  </div>
</div>
