<div class="card shadow-sm p-5 text-center" data-destination="<%= @destination %>" id="mobile-splash-root">
  <%= image_tag "mobile/splash-icon.png", alt: "Kindling Splash", class: "img-fluid mb-3", style: "max-width: 140px;" %>
  <h1 class="h5 mb-2">Kindling</h1>
  <p class="text-muted mb-0">Loading your startup flow…</p>
</div>

<script>
  (() => {
    const root = document.getElementById("mobile-splash-root");
    if (!root) return;
    const destination = root.dataset.destination || "/mobile/intro";
    window.setTimeout(() => {
      window.location.assign(destination);
    }, 500);
  })();
</script>
