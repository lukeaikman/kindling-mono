<% content_for :title, "" %>

<section class="mobile-screen mobile-screen--startup"
  data-controller="splash-redirect"
  data-splash-redirect-url-value="<%= @destination %>">
  <div class="mobile-screen__body">
    <div class="mobile-brand">
      <%= image_tag "mobile/splash-icon.png", alt: "Kindling Splash", style: "width: 7rem; height: auto;" %>
    </div>

    <%= render "mobile/shared/hero_block",
      eyebrow: "Kindling",
      title: "Setting the stage",
      subtitle: "We’re opening the right part of your journey now.",
      center: true %>
  </div>
</section>
