<% content_for :title, "" %>

<%
  children_for_form = @onboarding_session.children_payload
  if @onboarding_session.has_children == "yes" && children_for_form.empty?
    children_for_form = [{
      "id" => SecureRandom.hex(6),
      "capacity_status" => "under-18",
      "disabled_answer" => nil,
      "lacks_mental_capacity_answer" => nil,
      "co_parent_type" => nil
    }]
  end
%>

<%= form_with model: @onboarding_session,
  url: mobile_onboarding_family_path,
  method: :patch,
  class: "mobile-screen mobile-screen--onboarding",
  html: {
    data: {
      controller: "family-form",
      action: "change->family-form#formChange click->family-form#formClick focusin->family-form#formFocusin input->family-form#formInput",
      family_form_user_last_name_value: @onboarding_session.last_name.to_s,
      family_form_partner_first_name_value: @onboarding_session.spouse_first_name.to_s,
      family_form_relationship_kind_value: @onboarding_session.relationship_status.to_s
    }
  } do |form| %>
  <%
    partner_fields_body = capture do
  %>
    <div class="mobile-inline-grid">
      <%= render "mobile/shared/form_row",
        label: "First name",
        for_id: "onboarding_session_spouse_first_name",
        body: capture { form.text_field :spouse_first_name, class: "mobile-input", autocomplete: "off", data: { role: "spouse-first-name" } } %>

      <%= render "mobile/shared/form_row",
        label: "Last name",
        for_id: "onboarding_session_spouse_last_name",
        body: capture { form.text_field :spouse_last_name, class: "mobile-input", autocomplete: "off", data: { role: "spouse-last-name", prefilled: (@onboarding_session.spouse_last_name.present? && @onboarding_session.spouse_last_name == @onboarding_session.last_name).to_s } } %>
    </div>

    <%= render "mobile/shared/date_field",
      field_name: "onboarding_session[partner_started_at]",
      id_prefix: "onboarding_session_partner_started_at",
      label: "Wedding date",
      hint: nil,
      value: @onboarding_session.partner_started_at,
      placeholder: "Select date",
      min: (Date.current - 100.years),
      max: Date.current,
      picker_title: "Wedding date",
      data_role: "partner-started-at" %>
  <% end %>

  <%
    children_section_body = capture do
  %>
    <%# Hidden by default — Stimulus shows it once Child 1's first_name has any
        content (or whenever there's already more than one card). "Add another"
        is misleading before any child has been started. %>
    <button type="button" class="mobile-button-secondary" data-add-child hidden>Add another</button>

    <div class="mobile-stack" data-children-list>
      <% children_for_form.each_with_index do |child, index| %>
        <%= render "child_fields",
          child: child,
          child_index: index,
          index: index,
          allow_remove: children_for_form.size > 1,
          partnered: @onboarding_session.has_partner?,
          partner_first_name: @onboarding_session.partner_display_name %>
      <% end %>
    </div>

    <template data-child-template>
      <%= render "child_fields",
        child: { "id" => "__CHILD_ID__", "capacity_status" => "under-18", "disabled_answer" => nil, "lacks_mental_capacity_answer" => nil, "co_parent_type" => nil },
        child_index: "__INDEX__",
        index: 0,
        allow_remove: true,
        partnered: @onboarding_session.has_partner?,
        partner_first_name: @onboarding_session.partner_display_name %>
    </template>
  <% end %>

  <%= render "mobile/shared/screen_header", step_number: 3, total_steps: 5 %>
  <%= render "mobile/shared/form_errors", record: @onboarding_session %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      title: "Your family.",
      subtitle: "This is where the flow becomes more personal. We keep it on one calm page so the whole picture stays visible." %>

    <div class="mobile-stack">
      <%= render "mobile/shared/choice_group",
        field_name: "onboarding_session[relationship_status]",
        label: "Which best describes your current situation?",
        value: @onboarding_session.relationship_status,
        options: [["Single", "single"], ["Married", "married"], ["Civil partnership", "civil-partnership"], ["Cohabiting", "cohabiting"], ["Widowed", "widowed"]],
        id_prefix: "relationship_status",
        collapsible: true,
        data_role: "relationship-status" %>

      <div data-role="partner-fields" <%= "hidden" unless @onboarding_session.has_partner? %>>
        <%= render "mobile/shared/grouped_section",
          title: "Partner details",
          subtle: true,
          body: partner_fields_body %>
      </div>

      <%= render "mobile/shared/form_row",
        label: "How many times have you been divorced?",
        for_id: "onboarding_session_times_divorced",
        body: capture {
          form.number_field :times_divorced,
            min: 0, step: 1,
            class: "mobile-input mobile-input--narrow",
            data: { role: "times-divorced" }
        } %>

      <div data-role="times-widowed-row" <%= "hidden" unless @onboarding_session.relationship_status == "widowed" %>>
        <%= render "mobile/shared/form_row",
          label: "How many times have you been widowed?",
          for_id: "onboarding_session_times_widowed",
          body: capture {
            form.number_field :times_widowed,
              min: 0, step: 1,
              class: "mobile-input mobile-input--narrow",
              data: { role: "times-widowed" }
          } %>
      </div>

      <%= render "mobile/shared/choice_group",
        field_name: "onboarding_session[has_children]",
        label: "Do you have children or guardianship responsibilities?",
        value: @onboarding_session.has_children,
        options: [["Yes", "yes"], ["No", "no"]],
        id_prefix: "has_children",
        collapsible: true,
        data_role: "has-children" %>
    </div>

    <div data-role="children-section" <%= "hidden" unless @onboarding_session.has_children == "yes" %>>
      <%= render "mobile/shared/grouped_section",
        title: "Tell us about those in your care",
        body: children_section_body %>
    </div>

    <div class="mobile-actions">
      <%= form.submit "Continue", class: "mobile-button", data: { controller: "haptic", haptic_style_value: "medium" } %>
    </div>
  </div>
<% end %>
