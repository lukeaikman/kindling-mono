<% content_for :title, "Kindling | Welcome" %>

<%= form_with model: @onboarding_session, url: mobile_onboarding_welcome_path, method: :patch, class: "mobile-screen mobile-screen--onboarding", html: { id: "mobile-welcome-form" } do |form| %>
  <% welcome_footer = capture do %>
    <%= form.submit "Continue", class: "mobile-button", form: "mobile-welcome-form" %>
    <%= link_to "Log in instead", mobile_login_path, class: "mobile-button-tertiary" %>
  <% end %>

  <% welcome_body = capture do %>
    <%= render "mobile/shared/form_row",
      label: "First name",
      for_id: "onboarding_session_first_name",
      body: capture { form.text_field :first_name, class: "mobile-input", autocomplete: "given-name" } %>

    <%= render "mobile/shared/form_row",
      label: "Middle names (optional)",
      for_id: "onboarding_session_middle_names",
      body: capture { form.text_field :middle_names, class: "mobile-input", autocomplete: "additional-name" } %>

    <%= render "mobile/shared/form_row",
      label: "Family name / surname",
      for_id: "onboarding_session_last_name",
      body: capture { form.text_field :last_name, class: "mobile-input", autocomplete: "family-name" } %>

    <%= render "mobile/shared/form_row",
      label: "Date of birth",
      hint: "At the moment this flow supports people aged 18 to 90.",
      for_id: "onboarding_session_date_of_birth",
      body: capture { form.date_field :date_of_birth, class: "mobile-input" } %>
  <% end %>

  <% content_for :mobile_footer do %>
    <%= render "mobile/shared/sticky_actions", body: welcome_footer %>
  <% end %>

  <%= render "mobile/shared/screen_header", step_number: 1, total_steps: 5, back_path: mobile_intro_path %>
  <%= render "mobile/shared/form_errors", record: @onboarding_session %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      eyebrow: "Step 1",
      title: "Let’s start with you.",
      subtitle: "These details anchor the rest of the document, so we begin with the essentials and keep it clean." %>

    <%= render "mobile/shared/grouped_section",
      body: welcome_body %>
  </div>
<% end %>
