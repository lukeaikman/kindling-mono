<% content_for :title, "" %>

<%= form_with model: @person, scope: :person, url: mobile_onboarding_welcome_path, method: :patch, class: "mobile-screen mobile-screen--onboarding" do |form| %>
  <%= render "mobile/shared/screen_header", step_number: 1, total_steps: 5 %>
  <%= render "mobile/shared/form_errors", record: @person %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      title: "Let’s start with you.",
      subtitle: "These details anchor the rest of the document, so we begin with the essentials and keep it clean." %>

    <div class="mobile-stack">
      <%= render "mobile/shared/form_row",
        label: "First name",
        for_id: "person_first_name",
        body: capture { form.text_field :first_name, class: "mobile-input", autocomplete: "given-name" } %>

      <%= render "mobile/shared/form_row",
        label: "Middle names (optional)",
        for_id: "person_middle_names",
        body: capture { form.text_field :middle_names, class: "mobile-input", autocomplete: "additional-name" } %>

      <%= render "mobile/shared/form_row",
        label: "Family name / surname",
        for_id: "person_last_name",
        body: capture { form.text_field :last_name, class: "mobile-input", autocomplete: "family-name" } %>

      <%= render "mobile/shared/date_field",
        field_name: "person[date_of_birth]",
        id_prefix: "person_date_of_birth",
        label: "Date of birth",
        hint: "At the moment this flow supports people aged 18 to 90.",
        value: @person.date_of_birth,
        placeholder: "Select your date of birth",
        min: (Date.current - 120.years),
        max: (Date.current - 16.years) %>
    </div>

    <div class="mobile-actions">
      <%= form.submit "Continue", class: "mobile-button", data: { controller: "haptic", haptic_style_value: "medium" } %>
      <%= link_to "Log in instead", mobile_login_path, class: "mobile-button-tertiary" %>
    </div>
  </div>
<% end %>
