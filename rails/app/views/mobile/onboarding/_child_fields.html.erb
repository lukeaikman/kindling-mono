<%
  selected_responsibility = child["responsibility"].presence || default_responsibility
  responsibility_manual = child["responsibility"].present?
%>

<div class="mobile-child-card mobile-stack" data-child-card>
  <div class="mobile-child-topline">
    <h3 class="mobile-child-title">Child <span data-child-number><%= index + 1 %></span></h3>
    <button type="button" class="mobile-remove-button" data-remove-child <%= "hidden" if allow_remove == false %>>Remove</button>
  </div>

  <%= hidden_field_tag "onboarding_session[children_payload][#{child_index}][id]", child["id"] %>

  <div class="mobile-inline-grid">
    <div class="mobile-form-group">
      <label class="mobile-field-label">First name</label>
      <%= text_field_tag "onboarding_session[children_payload][#{child_index}][first_name]", child["first_name"], class: "mobile-input" %>
    </div>

    <div class="mobile-form-group">
      <label class="mobile-field-label">Last name</label>
      <%= text_field_tag "onboarding_session[children_payload][#{child_index}][last_name]", child["last_name"], class: "mobile-input", data: { role: "child-last-name", prefilled: child["last_name"].present?.to_s } %>
    </div>
  </div>

  <div class="mobile-form-group">
    <label class="mobile-field-label">Date of birth (optional)</label>
    <%= date_field_tag "onboarding_session[children_payload][#{child_index}][date_of_birth]", child["date_of_birth"], class: "mobile-input" %>
  </div>

  <div class="mobile-form-group">
    <label class="mobile-field-label">Relationship to you</label>
    <%= select_tag "onboarding_session[children_payload][#{child_index}][relationship]",
      options_for_select([["Biological child", "biological-child"], ["Adopted child", "adopted-child"], ["Stepchild", "stepchild"], ["Foster child", "foster-child"], ["Other", "other"]], child["relationship"] || "biological-child"),
      class: "mobile-select" %>
  </div>

  <div class="mobile-form-group">
    <label class="mobile-field-label">Responsibility</label>
    <%= select_tag "onboarding_session[children_payload][#{child_index}][responsibility]",
      options_for_select(responsibility_options, selected_responsibility),
      class: "mobile-select",
      data: { role: "responsibility", manual: responsibility_manual.to_s } %>
  </div>

  <div class="mobile-form-group">
    <label class="mobile-field-label">Capacity as guardian</label>
    <%= select_tag "onboarding_session[children_payload][#{child_index}][capacity_status]",
      options_for_select([["Child is under 18", "under-18"], ["Child is over 18 but lacks mental capacity", "over-18-lacks-capacity"], ["Child is over 18 with full capacity", "over-18-full-capacity"], ["Special circumstances", "special-circumstances"]], child["capacity_status"] || "under-18"),
      class: "mobile-select" %>
  </div>

  <div class="mobile-form-group">
    <p class="mobile-field-label">Is this child disabled?</p>
    <div class="mobile-radio-group" data-mobile-collapsible="true">
      <% [["Yes", "yes"], ["No", "no"]].each do |label, value| %>
        <% disabled_id = "child_#{child_index}_disabled_#{value}" %>
        <div class="mobile-radio-option">
          <%= radio_button_tag "onboarding_session[children_payload][#{child_index}][disabled_answer]", value, child["disabled_answer"] == value, id: disabled_id %>
          <%= label_tag disabled_id, label %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mobile-form-group">
    <p class="mobile-field-label">Does this child lack mental capacity?</p>
    <div class="mobile-radio-group" data-mobile-collapsible="true">
      <% [["Yes", "yes"], ["No", "no"]].each do |label, value| %>
        <% capacity_id = "child_#{child_index}_capacity_#{value}" %>
        <div class="mobile-radio-option">
          <%= radio_button_tag "onboarding_session[children_payload][#{child_index}][lacks_mental_capacity_answer]", value, child["lacks_mental_capacity_answer"] == value, id: capacity_id %>
          <%= label_tag capacity_id, label %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mobile-stack" data-role="co-guardian-fields" <%= "hidden" unless selected_responsibility == "add-co-guardian" %>>
    <p class="mobile-field-label mb-0">Guardian details</p>

    <div class="mobile-inline-grid">
      <div class="mobile-form-group">
        <label class="mobile-field-label">First name</label>
        <%= text_field_tag "onboarding_session[children_payload][#{child_index}][co_guardian_first_name]", child["co_guardian_first_name"], class: "mobile-input" %>
      </div>

      <div class="mobile-form-group">
        <label class="mobile-field-label">Last name</label>
        <%= text_field_tag "onboarding_session[children_payload][#{child_index}][co_guardian_last_name]", child["co_guardian_last_name"], class: "mobile-input" %>
      </div>
    </div>

    <div class="mobile-form-group">
      <label class="mobile-field-label">Relationship (optional)</label>
      <%= text_field_tag "onboarding_session[children_payload][#{child_index}][co_guardian_relationship]", child["co_guardian_relationship"], class: "mobile-input", placeholder: "Ex-partner, friend, sibling..." %>
    </div>
  </div>
</div>
