<%
  # `partner_first_name` carries either the actual partner first name (live)
  # or a fallback string ("your spouse" / "your civil partner" / "your partner").
  # The Stimulus controller live-updates this label as the user types in the
  # partner section. The server-side render uses the at-load value.
  partner_label = partner_first_name.presence || "your partner"
  co_parent_type = child["co_parent_type"]

  partnered_options = [
    ["Yes, with #{partner_label}", "yes_with_partner"],
    ["Yes, with someone else", "yes_with_other"],
    ["No — their other parent is deceased", "no_deceased"],
    ["No, I have sole parental responsibility", "no_sole"]
  ]
  unpartnered_options = [
    ["Yes", "yes_with_other"],
    ["No — their other parent is deceased", "no_deceased"],
    ["No, I have sole parental responsibility", "no_sole"]
  ]
  active_options = partnered ? partnered_options : unpartnered_options

  child_relationship_options = [
    ["Biological child", "biological-child"],
    ["Adopted child", "adopted-child"],
    ["Step child", "stepchild"],
    ["Foster child", "foster-child"]
  ]
  partner_relationship_to_child_options = [
    ["Biological parent", "biological"],
    ["Adoptive parent", "adoptive"],
    ["Step parent", "step"],
    ["Foster parent", "foster"]
  ]

  child_name_body = capture do
%>
  <div class="mobile-inline-grid">
    <%= render "mobile/shared/form_row",
      label: "First name",
      body: capture { text_field_tag "onboarding_session[children_payload][#{child_index}][first_name]", child["first_name"], class: "mobile-input" } %>

    <%= render "mobile/shared/form_row",
      label: "Last name",
      body: capture { text_field_tag "onboarding_session[children_payload][#{child_index}][last_name]", child["last_name"], class: "mobile-input", data: { role: "child-last-name", prefilled: child["last_name"].present?.to_s } } %>
  </div>
<% end %>

<%
  someone_else_body = capture do
%>
  <div class="mobile-inline-grid">
    <%= render "mobile/shared/form_row",
      label: "Their first name",
      body: capture { text_field_tag "onboarding_session[children_payload][#{child_index}][co_parent_other_first_name]", child["co_parent_other_first_name"], class: "mobile-input" } %>

    <%= render "mobile/shared/form_row",
      label: "Their last name",
      body: capture { text_field_tag "onboarding_session[children_payload][#{child_index}][co_parent_other_last_name]", child["co_parent_other_last_name"], class: "mobile-input" } %>
  </div>

  <%= render "mobile/shared/picker_field",
    field_name: "onboarding_session[children_payload][#{child_index}][co_parent_other_relationship_to_child]",
    label: "Their relationship to this child",
    value: child["co_parent_other_relationship_to_child"],
    options: partner_relationship_to_child_options,
    placeholder: "Select relationship",
    id_prefix: "child_#{child_index}_co_parent_other_rel" %>
<% end %>

<div class="mobile-child-card" data-child-card data-partnered="<%= partnered %>">
  <div class="mobile-child-topline">
    <h3 class="mobile-child-title">Child <span data-child-number><%= index + 1 %></span></h3>
    <button type="button" class="mobile-remove-button" data-remove-child <%= "hidden" if allow_remove == false %>>Remove</button>
  </div>

  <%= hidden_field_tag "onboarding_session[children_payload][#{child_index}][id]", child["id"] %>

  <%= child_name_body %>

  <%= render "mobile/shared/date_field",
    field_name: "onboarding_session[children_payload][#{child_index}][date_of_birth]",
    id_prefix: "child_#{child_index}_date_of_birth",
    label: "Date of birth (optional)",
    value: child["date_of_birth"],
    placeholder: "Select date of birth",
    min: (Date.current - 100.years),
    max: Date.current %>

  <%= render "mobile/shared/choice_group",
    field_name: "onboarding_session[children_payload][#{child_index}][relationship]",
    label: "What is this child's relationship to you?",
    value: child["relationship"] || "biological-child",
    options: child_relationship_options,
    id_prefix: "child_#{child_index}_relationship",
    collapsible: true %>

  <%# Co-parent radio (always shown — covers ex-partners + previous marriages
      where current relationship_status doesn't apply). Stimulus re-renders
      labels as relationship_status / partner-name change.
      Note: each block below is a direct child of `.mobile-child-card` so the
      grid `gap` rule spaces them uniformly with the surrounding form rows. %>
  <%= render "mobile/shared/choice_group",
    field_name: "onboarding_session[children_payload][#{child_index}][co_parent_type]",
    label: "Do you share legal responsibility for this child?",
    value: co_parent_type,
    options: active_options,
    id_prefix: "child_#{child_index}_co_parent_type",
    collapsible: true,
    data_role: "co-parent-type" %>

  <div data-role="co-parent-partner-rel" <%= "hidden" unless co_parent_type == "yes_with_partner" %>>
    <%= render "mobile/shared/picker_field",
      field_name: "onboarding_session[children_payload][#{child_index}][co_parent_partner_relationship_to_child]",
      label: "Their relationship to this child",
      value: child["co_parent_partner_relationship_to_child"],
      options: partner_relationship_to_child_options,
      placeholder: "Select relationship",
      id_prefix: "child_#{child_index}_co_parent_partner_rel" %>
  </div>

  <div data-role="co-parent-other-fields" <%= "hidden" unless co_parent_type == "yes_with_other" %>>
    <%= render "mobile/shared/grouped_section",
      title: "Other parent details",
      subtle: true,
      body: someone_else_body %>
  </div>

  <%= render "mobile/shared/choice_group",
    field_name: "onboarding_session[children_payload][#{child_index}][disabled_answer]",
    label: "Is this child disabled?",
    value: child["disabled_answer"],
    options: [["Yes", "yes"], ["No", "no"]],
    id_prefix: "child_#{child_index}_disabled",
    collapsible: true %>

  <%= render "mobile/shared/choice_group",
    field_name: "onboarding_session[children_payload][#{child_index}][lacks_mental_capacity_answer]",
    label: "Does this child lack mental capacity?",
    value: child["lacks_mental_capacity_answer"],
    options: [["Yes", "yes"], ["No", "no"]],
    id_prefix: "child_#{child_index}_lacks_mental_capacity",
    collapsible: true %>
</div>
