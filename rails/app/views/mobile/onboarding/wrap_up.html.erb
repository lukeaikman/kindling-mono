<% content_for :title, "" %>

<% covered_body = capture do %>
  <p class="mobile-copy">Your core identity, your location, the structure of your family, and the details that change legal outcomes.</p>
<% end %>

<% next_body = capture do %>
  <p class="mobile-copy">Account security and ownership, so the work you’ve done becomes yours to return to and build on.</p>
<% end %>

<section class="mobile-screen mobile-screen--onboarding">
  <%= render "mobile/shared/screen_header", step_number: 5, total_steps: 5 %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      title: "You’ve covered the right ground.",
      subtitle: "We’ve collected the essential facts. Next comes securing your account so this can become a durable, properly owned plan." %>

    <%= render "mobile/shared/grouped_section",
      title: "What we’ve covered",
      body: covered_body %>

    <%= render "mobile/shared/grouped_section",
      title: "Coming up next",
      subtle: true,
      body: next_body %>

    <div class="mobile-actions">
      <%= button_to "Continue", mobile_onboarding_wrap_up_continue_path, method: :post, class: "mobile-button", data: { controller: "haptic", haptic_style_value: "medium" } %>
    </div>
  </div>
</section>
