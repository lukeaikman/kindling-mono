<% content_for :title, "" %>

<%# Wave 2 Commit 3b: partner-data conditional now reads from current_user
    (active_marriage). @onboarding_session no longer carries family state. %>
<%= form_with model: @person, scope: :person, url: mobile_onboarding_extended_family_path, method: :patch, class: "mobile-screen mobile-screen--onboarding", html: { data: { controller: "extended-family-form", action: "change->extended-family-form#changed" } } do |form| %>
  <%= render "mobile/shared/screen_header", step_number: 4, total_steps: 5 %>
  <%= render "mobile/shared/form_errors", record: @person %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      title: "Extended family.",
      subtitle: "A few more facts help us understand complexity without dragging you through a family tree exercise." %>

    <div class="mobile-stack">
      <%= render "mobile/shared/choice_group",
        field_name: "person[parents_alive]",
        label: "Are either of your parents still alive?",
        value: @person.parents_alive,
        options: [["Both", "both"], ["One alive", "one-alive"], ["No", "no"]],
        id_prefix: "parents_alive",
        collapsible: true %>

      <% if current_user.has_partner? %>
        <%= render "mobile/shared/choice_group",
          field_name: "person[parents_in_law_alive]",
          label: "Are either of #{current_user.partner_possessive_label} parents still alive?",
          value: @person.parents_in_law_alive,
          options: [["Both", "both"], ["One alive", "one-alive"], ["No", "no"]],
          id_prefix: "parents_in_law_alive",
          collapsible: true %>
      <% end %>

      <%= render "mobile/shared/choice_group",
        field_name: "person[siblings_alive]",
        label: "Do you have any brothers or sisters still alive?",
        value: @person.siblings_alive,
        options: [["Yes", "yes"], ["No", "no"]],
        id_prefix: "siblings_alive",
        collapsible: true,
        data_role: "siblings-alive" %>

      <div data-role="siblings-count" <%= "hidden" unless @person.siblings_alive == "yes" %>>
        <%= render "mobile/shared/form_row",
          label: "How many siblings are alive?",
          for_id: "person_number_of_siblings",
          body: capture { form.number_field :number_of_siblings, class: "mobile-input-number", min: 1 } %>
      </div>
    </div>

    <div class="mobile-actions">
      <%= form.submit "Continue", class: "mobile-button", data: { controller: "haptic", haptic_style_value: "medium" } %>
    </div>
  </div>
<% end %>
