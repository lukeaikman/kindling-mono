<%
  select_id = (local_assigns[:id_prefix].presence || field_name.gsub(/[^a-zA-Z0-9]+/, "_").gsub(/\A_|_\z/, ""))
  placeholder_text = local_assigns[:placeholder] || "Select a date"
  value_iso = value.is_a?(Date) ? value.iso8601 : value.presence
  min_iso = local_assigns[:min].present? ? (local_assigns[:min].respond_to?(:iso8601) ? local_assigns[:min].iso8601 : local_assigns[:min]) : nil
  max_iso = local_assigns[:max].present? ? (local_assigns[:max].respond_to?(:iso8601) ? local_assigns[:max].iso8601 : local_assigns[:max]) : nil
  picker_title = local_assigns[:picker_title] || label
  date_control = capture do
%>
<div class="mobile-date"
    data-controller="date-field"
    data-date-field-title-value="<%= picker_title %>"
    data-date-field-placeholder-value="<%= placeholder_text %>">
    <div class="mobile-input mobile-date__display">
      <span class="mobile-date__label is-placeholder" data-date-field-target="label"><%= placeholder_text %></span>
    </div>

    <%= date_field_tag field_name,
      value_iso,
      id: select_id,
      class: "mobile-date__input",
      min: min_iso,
      max: max_iso,
      data: { date_field_target: "input", action: "click->date-field#open change->date-field#sync" } %>
  </div>
<% end %>

<%= render "mobile/shared/form_row",
  label: label,
  hint: local_assigns[:hint],
  for_id: select_id,
  body: date_control %>
