<% content_for :title, "" %>

<% footer_actions = capture do %>
  <%= button_to "Log out", session_path, method: :delete, class: "mobile-button-secondary" %>
<% end %>

<% content_for :mobile_footer do %>
  <%= render "mobile/shared/sticky_actions", body: footer_actions %>
<% end %>

<section class="mobile-screen">
  <%= render "mobile/shared/screen_header", center_label: "Dashboard" %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      eyebrow: "Mobile dashboard",
      title: "You’re in.",
      subtitle: "This Epic 2 placeholder proves the authenticated mobile path cleanly bypasses onboarding and stays inside the mobile shell." %>

    <%= render "mobile/shared/callout",
      title: "What this means",
      body: "Authenticated users no longer bounce through anonymous onboarding routes. They land here directly." %>
  </div>
</section>
