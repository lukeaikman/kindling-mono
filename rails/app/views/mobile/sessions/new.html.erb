<% content_for :title, "" %>

<%= form_with url: mobile_login_path, method: :post, class: "mobile-screen mobile-screen--auth", html: { id: "mobile-login-form" } do |form| %>
  <% login_footer = capture do %>
    <%= form.submit "Log in", class: "mobile-button", form: "mobile-login-form", data: { controller: "haptic", haptic_style_value: "medium" } %>
    <%= link_to "Back to the start", mobile_intro_path, class: "mobile-button-tertiary" %>
  <% end %>

  <% login_body = capture do %>
    <%= render "mobile/shared/form_row",
      label: "Email",
      for_id: "email_address",
      body: capture { form.email_field :email_address, value: @email_address, required: true, autofocus: true, class: "mobile-input", placeholder: "you@example.com" } %>

    <%= render "mobile/shared/form_row",
      label: "Password",
      for_id: "password",
      body: capture { form.password_field :password, required: true, class: "mobile-input", placeholder: "Enter your password" } %>
  <% end %>

  <% content_for :mobile_footer do %>
    <%= render "mobile/shared/sticky_actions", body: login_footer %>
  <% end %>

  <%= render "mobile/shared/screen_header" %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      eyebrow: "Welcome back",
      title: "Log in and pick up from your dashboard.",
      subtitle: "Your dashboard lives behind the same Rails session auth as the admin surface, but this mobile view keeps the experience inside the app shell." %>

    <% if @has_onboarding_data %>
      <%= render "mobile/shared/callout",
        kind: "warning",
        title: "You’ve started onboarding.",
        body: "Logging in to an existing account will discard the answers you’ve given during onboarding so far." %>
      <div class="mobile-actions">
        <%= link_to "Pick up onboarding", current_user.first_incomplete_path, class: "mobile-button-secondary" %>
      </div>
    <% end %>

    <%= render "mobile/shared/grouped_section",
      body: login_body %>
  </div>
<% end %>
