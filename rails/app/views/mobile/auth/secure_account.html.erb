<% content_for :title, "" %>

<section class="mobile-screen mobile-screen--auth">
  <%= render "mobile/shared/screen_header", step_number: 5, total_steps: 5 %>

  <div class="mobile-screen__body">
    <%= render "mobile/shared/hero_block",
      eyebrow: "Next step",
      title: "Secure your account.",
      subtitle: "Your onboarding is complete. Account setup lands here next, and this route now exists as the concrete handoff from Epic 2 onward." %>

    <%= render "mobile/shared/callout",
      kind: "info",
      title: "Current build",
      body: "Epic 3 will replace this holding page with the real account-creation experience without changing the route or the user journey." %>
  </div>
</section>
